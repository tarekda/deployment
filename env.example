# ---------- Global ----------
TZ=UTC

# ---------- Ports ----------
FRONTEND_PORT=5173
BACKEND_PORT=3000
RABBITMQ_MGMT_PORT=15672

# ---------- MySQL (installed on VM host) ----------
# Containers reach host MySQL via host.docker.internal (see extra_hosts in docker-compose.yml).
# On the VM, create the database/user once, then run init scripts from:
#   ../radius-docker-image/mysql/init/01-schema.sql
#   ../radius-docker-image/mysql/init/02-radius_procedures.sql
# (skip 03-seed.sql in production unless you want test data)
#
# Host MySQL must accept connections from Docker (not only 127.0.0.1):
#   bind-address = 0.0.0.0   (or your VM LAN IP)
#   log_bin_trust_function_creators = 1   (see radius-docker-image/mysql/conf.d/my.cnf)
DB_HOST=host.docker.internal
DB_PORT=3306
DB_NAME=radius
DB_USERNAME=radius
DB_PASSWORD=change_me_radius

# ---------- Backend ----------
JWT_SECRET=change_me_jwt

# backups (run inside backend container; uses DB_HOST above)
BACKUP_DB_MODE=local
BACKUP_MYSQLDUMP_PATH=/usr/bin/mysqldump
BACKUP_DB_TIMEOUT_SECONDS=3600

# ---------- Frontend ----------
API_URL=http://localhost:3000/api
VITE_API_URL=http://localhost:3000/api

# ---------- FreeRADIUS ----------
RADIUS_DAILY_RESET_ENABLED=1
RADIUS_DAILY_RESET_AT=00:00

SQL_SERVER=host.docker.internal
SQL_PORT=3306
SQL_DATABASE=radius
SQL_USER=radius
SQL_PASSWORD=change_me_radius

# ---------- RabbitMQ / Redis ----------
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
REDIS_URL=redis://redis:6379
