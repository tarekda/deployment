# Radius Pro — unified deployment environment
# Copy to .env:  cp env.example .env   (never commit .env)

# ---------- Global ----------
TZ=UTC

# ---------- Ports ----------
FRONTEND_PORT=5173
BACKEND_PORT=3000
RABBITMQ_MGMT_PORT=15672

# ---------- MySQL (installed on VM host) ----------
# Containers reach host MySQL via host.docker.internal (extra_hosts in docker-compose.yml).
# One-time on VM:
#   mysql ... < ../radius-docker-image/mysql/init/01-schema.sql
#   mysql ... < ../radius-docker-image/mysql/init/02-radius_procedures.sql
# Host MySQL: bind-address = 0.0.0.0, log_bin_trust_function_creators = 1
DB_HOST=host.docker.internal
DB_PORT=3306
DB_NAME=radius
DB_USERNAME=radius
DB_PASSWORD=password

# ---------- Backend — auth (required) ----------
JWT_SECRET=your_jwt_secret
REFRESH_TOKEN_SECRET=change_me_refresh_jwt

# ---------- Backend — server ----------
LOG_FORMAT=json
DB_LOGGING_ENABLED=false

# ---------- Backend — Redis / RabbitMQ ----------
REDIS_URL=redis://redis:6379
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
RABBITMQ_MANAGEMENT_URL=http://rabbitmq:15672

# ---------- Backend — online session KPIs ----------
ONLINE_SESSION_STALE_SECONDS=300
ONLINE_SESSION_ACTIVE_SECONDS=120

# ---------- Backend — expiry disconnect job ----------
EXPIRY_DISCONNECT_CRON=*/5 * * * *
EXPIRY_DISCONNECT_BATCH=100
EXPIRY_DISCONNECT_RUN_ON_STARTUP=1

# ---------- Backend — connection log maintenance ----------
CONNECTION_LOGS_SUMMARY_CRON=*/1 * * * *
CONNECTION_LOGS_SUMMARY_REFRESH_HOURS=2
CONNECTION_LOGS_CLEANUP_CRON=20 3 * * *
CONNECTION_LOGS_RETENTION_DAYS=7
CONNECTION_LOGS_SUMMARY_RETENTION_DAYS=180
CONNECTION_LOGS_CLEANUP_BATCH_SIZE=10000
CONNECTION_LOGS_CLEANUP_MAX_BATCHES=20

# ---------- Backend — backups ----------
BACKUP_DB_MODE=local
BACKUP_MYSQLDUMP_PATH=/usr/bin/mysqldump
BACKUP_DB_TIMEOUT_SECONDS=3600
BACKUP_RETENTION_DAYS=14
BACKUP_CLEANUP_CRON=15 3 * * *
# Optional scheduled backups (uncomment to enable):
# BACKUP_DB_CRON=0 2 * * *
# BACKUP_MIKROTIK_CRON=30 2 * * *

# ---------- Backend — MikroTik (optional) ----------
MIKROTIK_IP=172.9.16.2
MIKROTIK_USERNAME=apiuser
MIKROTIK_PASSWORD=123456
MIKROTIK_API_PORT=8728
MIKROTIK_MONITOR_INTERFACE=ether6-OUT

# ---------- Backend — dunning (optional; leave DUNNING_CRON empty to disable) ----------
# DUNNING_CRON=0 9 * * *
# DUNNING_GRACE_DAYS=7

# ---------- Backend — WhatsApp / Twilio (optional) ----------
WHATSAPP_ENABLED=false
WHATSAPP_PROVIDER=cloud
# WHATSAPP_TOKEN=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=

# ---------- Frontend (build-time — baked into static JS) ----------
# Use the URL browsers will use to reach the API (not localhost if remote users).
# Examples:
#   VITE_API_URL=http://192.168.1.50:3000/api
#   VITE_API_URL=https://radius.example.com/api
VITE_API_URL=http://localhost:3000/api

# ---------- FreeRADIUS ----------
RADIUS_DAILY_RESET_ENABLED=1
RADIUS_DAILY_RESET_AT=00:00
FREERADIUS_DEBUG=0

SQL_SERVER=host.docker.internal
SQL_PORT=3306
SQL_DATABASE=radius
SQL_USER=radius
SQL_PASSWORD=password
